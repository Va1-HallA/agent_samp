# dev / prod. Production must have both fallbacks disabled.
APP_ENV=dev

# ---------- AWS ----------
AWS_REGION=us-east-1

# Bedrock model IDs (Converse API).
# Main / merge / specialist agents:
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0
# Lightweight router (classification):
BEDROCK_ROUTER_MODEL_ID=anthropic.claude-haiku-4-5-20251001-v1:0
# Embeddings:
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
EMBEDDING_DIM=1024

MAX_TOKENS=2048
MAX_STEPS=10
LLM_TIMEOUT=30
LLM_MAX_RETRIES=3

# ---------- OpenSearch (dense + sparse retrieval) ----------
# Drop the https:// prefix; just the host.
OPENSEARCH_ENDPOINT=search-care-knowledge-xxxxxx.us-east-1.es.amazonaws.com
OPENSEARCH_INDEX=care-knowledge

# ---------- RDS PostgreSQL ----------
# Runtime reads PG_SECRET_ID from Secrets Manager and assembles the URL.
# For local dev you can still override DATABASE_URL directly.
PG_SECRET_ID=care-agent/rds/credentials
DATABASE_URL=

# ---------- DynamoDB (session memory) ----------
DYNAMODB_SESSION_TABLE=care-agent-sessions
SESSION_TTL_SECONDS=86400

# ---------- Multi-tenant + rate limit ----------
DEFAULT_TENANT_ID=default
RATE_LIMIT_PER_TENANT=60/minute
TENANT_SOURCE=header
TENANT_HEADER=X-Tenant-ID
TRUSTED_TENANT_HEADER=X-Verified-Tenant-ID

# ---------- Fallbacks (dev only; disable in production) ----------
ALLOW_INPROC_MEMORY_FALLBACK=1
ALLOW_LOCAL_KB_FALLBACK=1

# ---------- Knowledge index offline-build ----------
KNOWLEDGE_DOCS_DIR=data/knowledge_docs
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Cache is disabled by default (we no longer run Redis on AWS).
CACHE_ENABLED=0
CACHE_TTL_SECONDS=300
