ANTHROPIC_API_KEY=sk-ant-xxx

# dev / prod
APP_ENV=dev

POSTGRES_URL=postgresql://dev:somedev@localhost:5432/health_agent

REDIS_HOST=localhost
REDIS_PORT=6379

# Main model (merge, triage, protocol).
MODEL_NAME=claude-opus-4-7
# Router model (lightweight classification).
ROUTER_MODEL=claude-haiku-4-5-20251001
MAX_TOKENS=2048
MAX_STEPS=10
LLM_TIMEOUT=30
LLM_MAX_RETRIES=3

# Query cache.
CACHE_ENABLED=1
CACHE_TTL_SECONDS=300

# Multi-tenant.
DEFAULT_TENANT_ID=default
RATE_LIMIT_PER_TENANT=60/minute
TENANT_SOURCE=header
TENANT_HEADER=X-Tenant-ID
TRUSTED_TENANT_HEADER=X-Verified-Tenant-ID

# Fallbacks: enable in dev, disable in prod.
ALLOW_INPROC_MEMORY_FALLBACK=1
ALLOW_LOCAL_KB_FALLBACK=1
SESSION_TTL_SECONDS=86400

KNOWLEDGE_DOCS_DIR=data/knowledge_docs
